## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
publish/

# ASP.NET Core
appsettings.Development.json
appsettings.Local.json
secrets.json

# Logs
*.log
logs/

# Rider
.idea/

# VS Code
.vscode/

# Visual Studio Code workspace
*.code-workspace

# NuGet
*.nupkg
packages/
!packages/build/
*.nuget.props
*.nuget.targets

# Entity Framework
*.mdf
*.ldf

# IIS Express
.vs/
iisexpress/

# Publish output
wwwroot/dist/
wwwroot/lib/

# Node modules (if frontend exists)
node_modules/

# Environment files
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# Test Results
TestResults/
*.trx

# Resharper
_ReSharper*/
*.DotSettings.user

# DotCover
*.dotCover

# Azure
PublishScripts/

# Docker
docker-compose.override.yml

# Generated files
Generated\ Files/

# Coverage reports
coverage/
*.coverage
*.coveragexml

# SQLite
*.db
*.sqlite

# Temporary files
*.tmp
*.temp

# Certificates
*.pfx
*.pem
*.key

# JetBrains Rider
*.sln.iml